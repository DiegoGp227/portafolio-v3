---
---

<section id="hero">
  <div class="hero-left">
    <div class="hero-label reveal">
      <span class="available-dot"></span>
      Disponible para nuevas oportunidades
    </div>

    <h1 class="hero-name reveal reveal-delay-1">
      <span>Frontend</span>
      <span class="accent-word glitch" data-text="Developer">Developer</span>
    </h1>

    <p class="hero-desc reveal reveal-delay-2">
      Construyo interfaces web rápidas, accesibles y mantenibles.
      Trabajo con React y Next.js en entornos de producción —
      enfocado en calidad de código, experiencia de usuario y entregas reales.
    </p>

    <div class="hero-meta reveal reveal-delay-3">
      <span class="hero-meta-item">React · Next.js · TypeScript</span>
      <span class="hero-meta-sep">·</span>
      <span class="hero-meta-item">Diego Gongora</span>
    </div>

    <div class="hero-cta reveal reveal-delay-4">
      <a href="#projects" class="btn-primary">Ver proyectos</a>
      <a href="#contact"  class="btn-ghost">Contactar</a>
    </div>
  </div>

  <div class="hero-right reveal reveal-delay-2">
    <div class="avatar-wrap">
      <div class="avatar-bg"></div>
      <div class="avatar-img">
        <div class="avatar-placeholder">&#128100;</div>
      </div>
      <div class="avatar-badge">
        <div class="badge-number">6</div>
        <div class="badge-label">proyectos en producción</div>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    Scroll
  </div>
</section>
