---
const links = [
  { href: '#about',        label: 'About' },
  { href: '#technologies', label: 'Tech' },
  { href: '#projects',     label: 'Projects' },
  { href: '#contact',      label: 'Contact' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-100 flex items-center justify-between px-15 py-6 backdrop-blur-xl border-b border-transparent transition-all duration-300">
  <div class="nav-logo font-mono text-sm text-accent tracking-widest uppercase">// DG.dev</div>
  <ul class="nav-links flex gap-10 list-none">
    {links.map((link) => (
      <li><a href={link.href} class="text-xs tracking-widest uppercase text-muted hover:text-text transition-colors duration-200 relative">{link.label}</a></li>
    ))}
  </ul>
</nav>
