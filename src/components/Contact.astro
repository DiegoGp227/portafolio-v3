---
const socials = [
  { label: 'Email',    handle: 'diego.gp227@gmail.com',              href: 'mailto:diego.gp227@gmail.com' },
  { label: 'LinkedIn', handle: 'linkedin.com/in/diego-gongora-p',    href: 'https://www.linkedin.com/in/diego-gongora-p' },
  { label: 'GitHub',   handle: 'github.com/DiegoGp227',              href: 'https://github.com/DiegoGp227' },
];
---

<section id="contact">
  <div class="contact-left">
    <div class="section-label reveal">Contacto</div>
    <h2 class="section-title reveal reveal-delay-1">
      Disponible para<br /><em>su equipo.</em>
    </h2>
    <p class="contact-tagline reveal reveal-delay-2">
      Abierto a posiciones frontend en empresas que valoren
      el código bien hecho, la entrega constante y trabajar
      con propósito. Respondo en menos de 24h.
    </p>
    <div class="contact-links reveal reveal-delay-3">
      {socials.map((s) => (
        <a href={s.href} target="_blank" rel="noopener noreferrer" class="contact-link-row">
          <span class="contact-link-label">{s.label}</span>
          <span class="contact-link-handle">{s.handle}</span>
          <span class="contact-arrow">→</span>
        </a>
      ))}
    </div>
  </div>

  <div class="reveal reveal-delay-2">
    <form class="contact-form" id="contact-form">
      <input type="hidden" name="_captcha" value="false" />
      <input type="text" name="_honey" style="display:none" />

      <div class="form-group">
        <label class="form-label">Empresa / Nombre</label>
        <input type="text" name="name" class="form-input" placeholder="Acme Corp." required />
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-input" placeholder="rrhh@empresa.com" required />
      </div>
      <div class="form-group">
        <label class="form-label">Posición / Mensaje</label>
        <textarea name="message" class="form-textarea" placeholder="Cuéntame sobre el rol o proyecto..." required></textarea>
      </div>

      <div id="form-feedback" class="form-feedback" aria-live="polite"></div>

      <button class="btn-primary form-submit" type="submit" id="form-btn">Enviar</button>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('form-btn') as HTMLButtonElement;
  const feedback = document.getElementById('form-feedback') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.textContent = 'Enviando...';
    feedback.textContent = '';
    feedback.className = 'form-feedback';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('https://formsubmit.co/ajax/diego.gp227@gmail.com', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        feedback.textContent = '✓ Mensaje enviado. Te respondo en menos de 24h.';
        feedback.classList.add('form-feedback--ok');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      feedback.textContent = '✗ No se pudo enviar. Escríbeme directo a diego.gp227@gmail.com';
      feedback.classList.add('form-feedback--err');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar';
    }
  });
</script>
