---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import { getIcon } from '../../data/tech-icons';

const features = [
  { title: 'Registro de ingresos y gastos', desc: 'Con fecha, descripción y categoría. Historial completo con filtros por período.' },
  { title: 'Clasificación por categorías', desc: 'Agrupa movimientos para tener una visión clara de en qué se va el dinero.' },
  { title: 'Gestión de deudas', desc: 'Registra deudas con monto total y seguimiento del estado de pago.' },
  { title: 'Lista de metas / sueños', desc: 'Metas personalizables para visualizar objetivos financieros a largo plazo.' },
  { title: 'Datos privados por usuario', desc: 'Cada cuenta es completamente aislada. Autenticación con contraseña encriptada.' },
  { title: 'Dashboard de resumen', desc: 'Visualización rápida del estado financiero: balance, últimos movimientos y alertas.' },
];

const stack = ['Next.js', 'React', 'TypeScript', 'Node.js', 'Express', 'MySQL', 'Prisma'];
---

<ProjectLayout title="MyCash" description="Aplicación web para gestionar finanzas personales de manera sencilla.">

  <div class="ppage-hero">
    <div class="ppage-meta">
      <span class="ppage-num">002</span>
      <span class="ppage-status dev">En desarrollo</span>
    </div>
    <h1 class="ppage-title">MyCash</h1>
    <p class="ppage-subtitle">Gestión de finanzas personales</p>
    <p class="ppage-desc">
      Aplicación para que cualquier persona tenga control real de su dinero sin
      depender de hojas de cálculo. Ingresos, gastos, deudas y metas en un solo lugar,
      con una interfaz clara y sin distracciones.
    </p>
    <div class="ppage-links">
      <a href="https://coinmaster.devdiego.work/" target="_blank" rel="noopener noreferrer" class="btn-primary">Ver en vivo</a>
      <a href="https://github.com/DiegoGp227/CoinMaster-v2" target="_blank" rel="noopener noreferrer" class="btn-ghost">GitHub</a>
    </div>
  </div>

  <div class="browser-frame">
    <div class="browser-topbar">
      <div class="fake-dot r"></div>
      <div class="fake-dot y"></div>
      <div class="fake-dot g"></div>
      <span class="browser-url">coinmaster.devdiego.work</span>
    </div>
    <div class="browser-screen">
      <img src="/Projects/CoinMaster.png" alt="MyCash screenshot" loading="lazy" />
    </div>
  </div>

  <div class="ppage-section">
    <div class="section-label">Funcionalidades</div>
    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-title">{f.title}</div>
          <div class="feature-desc">{f.desc}</div>
        </div>
      ))}
    </div>
  </div>

  <div class="ppage-section">
    <div class="section-label">Stack técnico</div>
    <div class="stack-icon-grid">
      {stack.map((name) => {
        const icon = getIcon(name);
        return (
          <div class="stack-icon-card">
            {icon
              ? <img src={icon} alt={name} loading="lazy" />
              : <span class="stack-icon-fallback">{name.slice(0, 2).toUpperCase()}</span>
            }
            <span>{name}</span>
          </div>
        );
      })}
    </div>
  </div>

</ProjectLayout>
